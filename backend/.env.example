# Copy to .env and replace every dummy value before running outside local development.
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://schoolapp_user:schoolapp_password@localhost:5432/schoolapp_dev
JWT_SECRET=dummy_dev_jwt_secret_32_chars_minimum_change_me
TOTP_ENCRYPTION_KEY=dummy_totp_encryption_key_32_chars_minimum
AUTH_TWO_STEP_ENABLED=false
FRONTEND_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
LOG_LEVEL=debug
REDIS_URL=redis://localhost:6379
REDIS_CACHE_ENABLED=true
REDIS_CACHE_DEBUG=false
REDIS_CACHE_DASHBOARD_ENABLED=true
REDIS_CACHE_ANALYTICS_ENABLED=true
REDIS_CACHE_SCHOOLS_ENABLED=true
REDIS_CACHE_STUDENTS_ENABLED=true
REDIS_CACHE_TEACHERS_ENABLED=true
REDIS_CACHE_ATTENDANCE_ENABLED=true
REDIS_CACHE_NOTIFICATIONS_ENABLED=true
REDIS_CACHE_SUBSCRIPTIONS_ENABLED=true
REDIS_CACHE_THEMES_ENABLED=true
REDIS_CACHE_AUDIT_LOGS_ENABLED=true
REDIS_CACHE_MARKS_ENABLED=true
ATTENDANCE_ENABLED=true
TEACHER_SELF_ATTENDANCE_ENABLED=true
LEAVE_BASIC_ENABLED=true
WHATSAPP_FALLBACK_TO=0000000000
AWS_ACCESS_KEY_ID=dummy-access-key-id
AWS_SECRET_ACCESS_KEY=dummy-secret-access-key-change-me
AWS_REGION=us-east-1
AWS_S3_BUCKET=dummy-schoolapp-bucket
