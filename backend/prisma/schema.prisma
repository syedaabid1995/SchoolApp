generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SchoolStatus {
  ACTIVE
  SUSPENDED
}

enum SubscriptionPlan {
  STARTER
  STANDARD
  PREMIUM
}

model School {
  id               String           @id @default(uuid()) @db.Uuid
  name             String
  code             String           @unique
  subdomain        String?          @unique
  domainUrl        String?          @map("domain_url")
  status           SchoolStatus     @default(ACTIVE)
  subscriptionPlan SubscriptionPlan @map("subscription_plan")
  lastLoginAt      DateTime?        @map("last_login_at")
  activeUsersCount Int              @default(0) @map("active_users_count")
  statusReason     String?          @map("status_reason")
  deletedAt        DateTime?        @map("deleted_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  users                          User[]
  academicYears                  AcademicYear[]
  classes                        Class[]
  subjects                       Subject[]
  students                       Student[]
  teachers                       TeacherProfile[]
  importJobs                     ImportJob[]
  faceProfiles                   FaceProfile[]
  attendancePeriods              AttendancePeriod[]
  attendanceSessions             AttendanceSession[]
  studentAttendanceSessions      StudentAttendanceSession[]
  teacherSelfAttendances         TeacherSelfAttendance[]
  teacherLeaveRequests           TeacherLeaveRequest[]
  teacherAttendanceSubstitutions TeacherAttendanceSubstitution[]
  timetableVersions              TimetableVersion[]
  timetableEntries               TimetableEntry[]
  exams                          Exam[]
  examGradingSetting             ExamGradingSetting?
  examTypes                      ExamTypeConfig[]
  themes                         Theme[]
  featureFlagOverrides           FeatureFlagOverride[]
  configOverrides                TenantConfigOverride[]
  notificationLogs               NotificationLog[]
  backupJobs                     BackupJob[]
  subscription                   Subscription?
  usageCounter                   UsageCounter?
  otpCodes                       OtpCode[]
  consentRecords                 ConsentRecord[]
  dataExportJobs                 DataExportJob[]
  dataDeletionJobs               DataDeletionJob[]
  auditExports                   AuditExport[]
  supportTickets                 SupportTicket[]
  supportTicketComments          TicketComment[]
  messagingConfigs               SchoolMessagingConfig[]
  transferRequestsFrom           StudentTransferRequest[]        @relation("TransferFromSchool")
  transferRequestsTo             StudentTransferRequest[]        @relation("TransferToSchool")
  employeeRolePermissions        EmployeeRolePermission[]
  employeeUserPermissions        EmployeeUserPermission[]
  refreshSessions                RefreshSession[]
  passwordResetTokens            PasswordResetToken[]
  mfaChallenges                  MfaChallenge[]
  totpCredentials                TotpCredential[]
  totpBackupCodes                TotpBackupCode[]

  @@map("schools")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum RoleName {
  SUPER_ADMIN
  SCHOOL_ADMIN
  TEACHER
  ACCOUNTANT
  LIBRARIAN
  STAFF
  PARENT
}

model User {
  id                 String     @id @default(uuid()) @db.Uuid
  schoolId           String?    @map("school_id") @db.Uuid
  email              String
  passwordHash       String     @map("password_hash")
  mustChangePassword Boolean    @default(false) @map("must_change_password")
  mfaEnabled         Boolean    @default(false) @map("mfa_enabled")
  mfaMethod          String?    @map("mfa_method")
  status             UserStatus @default(ACTIVE)
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  school                                 School?                         @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  roles                                  UserRole[]
  parentProfiles                         ParentProfile[]
  teacherProfile                         TeacherProfile?
  bankDetails                            UserBankDetails?
  importJobs                             ImportJob[]
  faceProfilesCreated                    FaceProfile[]                   @relation("FaceProfileCreatedBy")
  faceProfilesApproved                   FaceProfile[]                   @relation("FaceProfileApprovedBy")
  attendanceSessions                     AttendanceSession[]
  attendanceAudits                       AttendanceAudit[]               @relation("AttendanceAuditActor")
  markModerations                        MarkModeration[]
  markRevaluations                       MarkRevaluation[]
  featureFlagOverrides                   FeatureFlagOverride[]
  notificationLogs                       NotificationLog[]
  backupRequests                         BackupJob[]
  restoreApprovals                       RestoreJob[]                    @relation("RestoreApprovedBy")
  restoreRequests                        RestoreJob[]                    @relation("RestoreRequestedBy")
  dataExportJobs                         DataExportJob[]
  dataDeletionRequests                   DataDeletionJob[]               @relation("DeletionRequestedBy")
  dataDeletionApprovals                  DataDeletionJob[]               @relation("DeletionApprovedBy")
  auditLogs                              AuditLog[]
  auditExports                           AuditExport[]
  supportTickets                         SupportTicket[]                 @relation("SupportTicketCreatedBy")
  assignedSupportTickets                 SupportTicket[]                 @relation("SupportTicketAssignedTo")
  supportTicketComments                  TicketComment[]                 @relation("SupportTicketCommentAuthor")
  transferRequestsCreated                StudentTransferRequest[]        @relation("TransferRequestedBy")
  transferRequestsDecided                StudentTransferRequest[]        @relation("TransferDecidedBy")
  studentAttendanceSessionsCreated       StudentAttendanceSession[]      @relation("StudentAttendanceSessionCreatedBy")
  studentAttendanceSessionsLocked        StudentAttendanceSession[]      @relation("StudentAttendanceSessionLockedBy")
  teacherSelfAttendancesCreated          TeacherSelfAttendance[]         @relation("TeacherSelfAttendanceCreatedBy")
  teacherSelfAttendancesOverridden       TeacherSelfAttendance[]         @relation("TeacherSelfAttendanceOverriddenBy")
  teacherLeaveRequestsReviewed           TeacherLeaveRequest[]           @relation("TeacherLeaveRequestReviewedBy")
  teacherAttendanceSubstitutionsCreated  TeacherAttendanceSubstitution[] @relation("TeacherAttendanceSubstitutionCreatedBy")
  teacherAttendanceSubstitutionsCanceled TeacherAttendanceSubstitution[] @relation("TeacherAttendanceSubstitutionCanceledBy")
  timetableVersionsCreated               TimetableVersion[]
  employeeUserPermissions                EmployeeUserPermission[]
  refreshSessions                        RefreshSession[]
  passwordResetTokens                    PasswordResetToken[]
  mfaChallenges                          MfaChallenge[]
  totpCredential                         TotpCredential?
  totpBackupCodes                        TotpBackupCode[]

  @@unique([schoolId, email])
  @@index([schoolId])
  @@map("users")
}

model RefreshSession {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  schoolId   String?   @map("school_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash")
  userAgent  String?   @map("user_agent")
  ipAddress  String?   @map("ip_address")
  deviceName String?   @map("device_name")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  school School? @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([schoolId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("refresh_sessions")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  schoolId  String?   @map("school_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  createdIp String?   @map("created_ip")
  userAgent String?   @map("user_agent")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  school School? @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([schoolId])
  @@index([expiresAt])
  @@index([usedAt])
  @@map("password_reset_tokens")
}

model MfaChallenge {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  schoolId    String?   @map("school_id") @db.Uuid
  otpHash     String    @map("otp_hash")
  purpose     String    @default("LOGIN")
  expiresAt   DateTime  @map("expires_at")
  verifiedAt  DateTime? @map("verified_at")
  attempts    Int       @default(0)
  maxAttempts Int       @default(5) @map("max_attempts")
  createdAt   DateTime  @default(now()) @map("created_at")
  createdIp   String?   @map("created_ip")
  userAgent   String?   @map("user_agent")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  school School? @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([schoolId])
  @@index([expiresAt])
  @@index([verifiedAt])
  @@map("mfa_challenges")
}

model TotpCredential {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @unique @map("user_id") @db.Uuid
  schoolId        String?   @map("school_id") @db.Uuid
  encryptedSecret String    @map("encrypted_secret")
  issuer          String
  label           String
  enabledAt       DateTime? @map("enabled_at")
  disabledAt      DateTime? @map("disabled_at")
  setupStartedAt  DateTime  @default(now()) @map("setup_started_at")
  lastUsedAt      DateTime? @map("last_used_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  school School? @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([schoolId])
  @@index([enabledAt])
  @@index([disabledAt])
  @@map("totp_credentials")
}

model TotpBackupCode {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  schoolId  String?   @map("school_id") @db.Uuid
  codeHash  String    @unique @map("code_hash")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  createdIp String?   @map("created_ip")
  userAgent String?   @map("user_agent")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  school School? @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([schoolId])
  @@index([usedAt])
  @@map("totp_backup_codes")
}

model Role {
  id        String   @id @default(uuid()) @db.Uuid
  name      RoleName @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  roles RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model EmployeeRolePermission {
  id             String   @id @default(uuid()) @db.Uuid
  schoolId       String   @map("school_id") @db.Uuid
  roleName       RoleName @map("role_name")
  permissionCode String   @map("permission_code")
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, roleName, permissionCode])
  @@index([schoolId, roleName])
  @@map("employee_role_permissions")
}

model EmployeeUserPermission {
  id             String   @id @default(uuid()) @db.Uuid
  schoolId       String   @map("school_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  permissionCode String   @map("permission_code")
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([schoolId, userId, permissionCode])
  @@index([schoolId, userId])
  @@map("employee_user_permissions")
}

model AcademicYear {
  id        String   @id @default(uuid()) @db.Uuid
  schoolId  String   @map("school_id") @db.Uuid
  name      String
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  isActive  Boolean  @default(false) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  school                         School                          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  terms                          Term[]
  exams                          Exam[]
  classes                        Class[]
  subjects                       Subject[]
  teacherAttendanceSubstitutions TeacherAttendanceSubstitution[]
  timetableVersions              TimetableVersion[]
  timetableEntries               TimetableEntry[]

  @@index([schoolId])
  @@map("academic_years")
}

model Term {
  id             String   @id @default(uuid()) @db.Uuid
  academicYearId String   @map("academic_year_id") @db.Uuid
  name           String
  startDate      DateTime @map("start_date")
  endDate        DateTime @map("end_date")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  exams        Exam[]

  @@unique([academicYearId, name])
  @@index([academicYearId])
  @@map("terms")
}

model Class {
  id             String   @id @default(uuid()) @db.Uuid
  schoolId       String   @map("school_id") @db.Uuid
  academicYearId String?  @map("academic_year_id") @db.Uuid
  name           String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  school                         School                          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear                   AcademicYear?                   @relation(fields: [academicYearId], references: [id], onDelete: SetNull)
  sections                       Section[]
  subjects                       Subject[]
  students                       Student[]
  exams                          Exam[]
  examPapers                     ExamPaper[]
  teacherAssignments             TeacherClassAssignment[]
  studentAttendanceSessions      StudentAttendanceSession[]
  teacherAttendanceSubstitutions TeacherAttendanceSubstitution[]
  timetableEntries               TimetableEntry[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([academicYearId])
  @@map("classes")
}

model Section {
  id        String   @id @default(uuid()) @db.Uuid
  classId   String   @map("class_id") @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  class                          Class                           @relation(fields: [classId], references: [id], onDelete: Cascade)
  students                       Student[]
  exams                          Exam[]
  studentAttendanceSessions      StudentAttendanceSession[]
  teacherAssignments             TeacherClassAssignment[]
  teacherAttendanceSubstitutions TeacherAttendanceSubstitution[]
  timetableEntries               TimetableEntry[]

  @@unique([classId, name])
  @@index([classId])
  @@map("sections")
}

model Subject {
  id             String   @id @default(uuid()) @db.Uuid
  schoolId       String   @map("school_id") @db.Uuid
  classId        String?  @map("class_id") @db.Uuid
  academicYearId String?  @map("academic_year_id") @db.Uuid
  name           String
  code           String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  school             School                     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class              Class?                     @relation(fields: [classId], references: [id], onDelete: SetNull)
  academicYear       AcademicYear?              @relation(fields: [academicYearId], references: [id], onDelete: SetNull)
  examPapers         ExamPaper[]
  teacherAssignments TeacherSubjectAssignment[]
  timetableEntries   TimetableEntry[]

  @@unique([schoolId, name, classId, academicYearId])
  @@index([schoolId])
  @@index([classId])
  @@index([academicYearId])
  @@map("subjects")
}

enum StudentStatus {
  ENROLLED
  TRANSFERRED
  EXITED
}

enum TransferRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Student {
  id                   String        @id @default(uuid()) @db.Uuid
  schoolId             String        @map("school_id") @db.Uuid
  classId              String?       @map("class_id") @db.Uuid
  sectionId            String?       @map("section_id") @db.Uuid
  admissionNo          String        @map("admission_no")
  firstName            String        @map("first_name")
  lastName             String        @map("last_name")
  fullName             String        @map("full_name")
  dob                  DateTime?     @map("dob")
  gender               String?       @map("gender")
  bloodGroup           String?       @map("blood_group")
  photoUrl             String?       @map("photo_url")
  fatherName           String?       @map("father_name")
  motherName           String?       @map("mother_name")
  guardianName         String?       @map("guardian_name")
  guardianRelationship String?       @map("guardian_relationship")
  parentPhone          String?       @map("parent_phone")
  parentEmail          String?       @map("parent_email")
  addressLine1         String?       @map("address_line1")
  addressLine2         String?       @map("address_line2")
  city                 String?       @map("city")
  state                String?       @map("state")
  pincode              String?       @map("pincode")
  emergencyContact     String?       @map("emergency_contact")
  medicalConditions    String?       @map("medical_conditions")
  allergies            String?       @map("allergies")
  doctorContact        String?       @map("doctor_contact")
  docBirthCert         String?       @map("doc_birth_cert")
  docTransferCert      String?       @map("doc_transfer_cert")
  docAadhaar           String?       @map("doc_aadhaar")
  docReportCard        String?       @map("doc_report_card")
  status               StudentStatus @default(ENROLLED)
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  school                   School                    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class                    Class?                    @relation(fields: [classId], references: [id], onDelete: SetNull)
  section                  Section?                  @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  parentLinks              StudentParent[]
  statusEvents             StudentStatusHistory[]
  transferRequests         StudentTransferRequest[]
  faceProfile              FaceProfile?
  attendanceRecords        AttendanceRecord[]
  studentAttendanceRecords StudentAttendanceRecord[]
  marks                    Mark[]
  photos                   StudentPhoto[]

  @@unique([schoolId, admissionNo])
  @@index([schoolId])
  @@index([classId])
  @@index([sectionId])
  @@map("students")
}

model StudentPhoto {
  id        String   @id @default(uuid()) @db.Uuid
  studentId String   @map("student_id") @db.Uuid
  url       String
  createdAt DateTime @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("student_photos")
}

model StudentTransferRequest {
  id            String                @id @default(uuid()) @db.Uuid
  studentId     String                @map("student_id") @db.Uuid
  fromSchoolId  String                @map("from_school_id") @db.Uuid
  toSchoolId    String                @map("to_school_id") @db.Uuid
  requestedById String                @map("requested_by_id") @db.Uuid
  decidedById   String?               @map("decided_by_id") @db.Uuid
  status        TransferRequestStatus @default(PENDING)
  reason        String?
  decidedAt     DateTime?             @map("decided_at")
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")

  student     Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  fromSchool  School  @relation("TransferFromSchool", fields: [fromSchoolId], references: [id], onDelete: Cascade)
  toSchool    School  @relation("TransferToSchool", fields: [toSchoolId], references: [id], onDelete: Cascade)
  requestedBy User    @relation("TransferRequestedBy", fields: [requestedById], references: [id], onDelete: Restrict)
  decidedBy   User?   @relation("TransferDecidedBy", fields: [decidedById], references: [id], onDelete: Restrict)

  @@index([studentId])
  @@index([fromSchoolId])
  @@index([toSchoolId])
  @@index([status])
  @@map("student_transfer_requests")
}

model ParentProfile {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  phone     String?
  email     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  links    StudentParent[]
  consents ConsentRecord[]

  @@unique([userId])
  @@index([userId])
  @@map("parent_profiles")
}

model TeacherProfile {
  id         String   @id @default(uuid()) @db.Uuid
  schoolId   String   @map("school_id") @db.Uuid
  userId     String   @unique @map("user_id") @db.Uuid
  employeeNo String?  @map("employee_no")
  firstName  String   @map("first_name")
  lastName   String   @map("last_name")
  phone      String?
  address    String?
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  school                              School                          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user                                User                            @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankDetails                         TeacherBankDetails?
  classAssignments                    TeacherClassAssignment[]
  subjectAssignments                  TeacherSubjectAssignment[]
  teacherSelfAttendances              TeacherSelfAttendance[]
  teacherLeaveRequests                TeacherLeaveRequest[]
  attendanceSubstitutionsAsOriginal   TeacherAttendanceSubstitution[] @relation("TeacherAttendanceSubstitutionOriginal")
  attendanceSubstitutionsAsSubstitute TeacherAttendanceSubstitution[] @relation("TeacherAttendanceSubstitutionSubstitute")
  timetableEntries                    TimetableEntry[]

  @@unique([schoolId, employeeNo])
  @@index([schoolId])
  @@map("employee_profiles")
}

model TeacherBankDetails {
  id                String   @id @default(uuid()) @db.Uuid
  teacherId         String   @unique @map("teacher_id") @db.Uuid
  accountHolderName String?  @map("account_holder_name")
  accountNumber     String?  @map("account_number")
  ifscCode          String?  @map("ifsc_code")
  accountType       String?  @map("account_type")
  bankName          String?  @map("bank_name")
  branchName        String?  @map("branch_name")
  panNumber         String?  @map("pan_number")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  teacher TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@map("teacher_bank_details")
}

model UserBankDetails {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @map("user_id") @db.Uuid
  accountHolderName String?  @map("account_holder_name")
  accountNumber     String?  @map("account_number")
  ifscCode          String?  @map("ifsc_code")
  accountType       String?  @map("account_type")
  bankName          String?  @map("bank_name")
  branchName        String?  @map("branch_name")
  panNumber         String?  @map("pan_number")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_bank_details")
}

model TeacherClassAssignment {
  id        String   @id @default(uuid()) @db.Uuid
  teacherId String   @map("teacher_id") @db.Uuid
