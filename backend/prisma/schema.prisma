generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SchoolStatus {
  ACTIVE
  SUSPENDED
}

enum SubscriptionPlan {
  STARTER
  STANDARD
  PREMIUM
}

model School {
  id               String       @id @default(uuid()) @db.Uuid
  name             String
  code             String       @unique
  status           SchoolStatus @default(ACTIVE)
  subscriptionPlan SubscriptionPlan @map("subscription_plan")
  lastLoginAt      DateTime?    @map("last_login_at")
  activeUsersCount Int          @default(0) @map("active_users_count")
  statusReason     String?      @map("status_reason")
  deletedAt        DateTime?    @map("deleted_at")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  users         User[]
  academicYears AcademicYear[]
  classes       Class[]
  subjects      Subject[]
  students      Student[]
  teachers      TeacherProfile[]
  importJobs    ImportJob[]
  faceProfiles  FaceProfile[]
  attendancePeriods AttendancePeriod[]
  attendanceSessions AttendanceSession[]
  exams Exam[]
  themes Theme[]
  featureFlagOverrides FeatureFlagOverride[]
  configOverrides TenantConfigOverride[]
  notificationLogs NotificationLog[]
  backupJobs BackupJob[]
  subscription Subscription?
  usageCounter UsageCounter?
  otpCodes OtpCode[]
  consentRecords ConsentRecord[]
  dataExportJobs DataExportJob[]
  dataDeletionJobs DataDeletionJob[]
  supportTickets SupportTicket[]
  messagingConfigs SchoolMessagingConfig[]
  transferRequestsFrom StudentTransferRequest[] @relation("TransferFromSchool")
  transferRequestsTo StudentTransferRequest[] @relation("TransferToSchool")
  employeeRolePermissions EmployeeRolePermission[]

  @@map("schools")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum RoleName {
  SUPER_ADMIN
  SCHOOL_ADMIN
  TEACHER
  ACCOUNTANT
  LIBRARIAN
  STAFF
  PARENT
}

model User {
  id           String      @id @default(uuid()) @db.Uuid
  schoolId     String?     @map("school_id") @db.Uuid
  email        String
  passwordHash String      @map("password_hash")
  mustChangePassword Boolean @default(false) @map("must_change_password")
  status       UserStatus  @default(ACTIVE)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  school School? @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  roles  UserRole[]
  parentProfiles ParentProfile[]
  teacherProfile TeacherProfile?
  bankDetails UserBankDetails?
  importJobs     ImportJob[]
  faceProfilesCreated FaceProfile[] @relation("FaceProfileCreatedBy")
  faceProfilesApproved FaceProfile[] @relation("FaceProfileApprovedBy")
  attendanceSessions AttendanceSession[]
  attendanceAudits AttendanceAudit[] @relation("AttendanceAuditActor")
  markModerations MarkModeration[]
  markRevaluations MarkRevaluation[]
  featureFlagOverrides FeatureFlagOverride[]
  notificationLogs NotificationLog[]
  backupRequests BackupJob[]
  restoreApprovals RestoreJob[] @relation("RestoreApprovedBy")
  restoreRequests RestoreJob[] @relation("RestoreRequestedBy")
  dataExportJobs DataExportJob[]
  dataDeletionRequests DataDeletionJob[] @relation("DeletionRequestedBy")
  dataDeletionApprovals DataDeletionJob[] @relation("DeletionApprovedBy")
  auditLogs AuditLog[]
  supportTickets SupportTicket[]
  transferRequestsCreated StudentTransferRequest[] @relation("TransferRequestedBy")
  transferRequestsDecided StudentTransferRequest[] @relation("TransferDecidedBy")

  @@index([schoolId])
  @@unique([schoolId, email])
  @@map("users")
}

model Role {
  id        String   @id @default(uuid()) @db.Uuid
  name      RoleName @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  roles RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model EmployeeRolePermission {
  id             String   @id @default(uuid()) @db.Uuid
  schoolId       String   @map("school_id") @db.Uuid
  roleName       RoleName @map("role_name")
  permissionCode String   @map("permission_code")
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, roleName, permissionCode])
  @@index([schoolId, roleName])
  @@map("employee_role_permissions")
}

model AcademicYear {
  id        String   @id @default(uuid()) @db.Uuid
  schoolId  String   @map("school_id") @db.Uuid
  name      String
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  isActive  Boolean  @default(false) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  terms  Term[]
  exams  Exam[]
  classes Class[]
  subjects Subject[]

  @@index([schoolId])
  @@map("academic_years")
}

model Term {
  id             String   @id @default(uuid()) @db.Uuid
  academicYearId String   @map("academic_year_id") @db.Uuid
  name           String
  startDate      DateTime @map("start_date")
  endDate        DateTime @map("end_date")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  exams Exam[]

  @@index([academicYearId])
  @@unique([academicYearId, name])
  @@map("terms")
}

model Class {
  id        String   @id @default(uuid()) @db.Uuid
  schoolId  String   @map("school_id") @db.Uuid
  academicYearId String? @map("academic_year_id") @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  school   School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear AcademicYear? @relation(fields: [academicYearId], references: [id], onDelete: SetNull)
  sections Section[]
  subjects Subject[]
  students Student[]
  exams Exam[]
  examPapers ExamPaper[]
  teacherAssignments TeacherClassAssignment[]

  @@index([schoolId])
  @@index([academicYearId])
  @@unique([schoolId, name])
  @@map("classes")
}

model Section {
  id        String   @id @default(uuid()) @db.Uuid
  classId   String   @map("class_id") @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  students Student[]
  exams Exam[]

  @@index([classId])
  @@unique([classId, name])
  @@map("sections")
}

model Subject {
  id        String   @id @default(uuid()) @db.Uuid
  schoolId  String   @map("school_id") @db.Uuid
  classId   String?  @map("class_id") @db.Uuid
  academicYearId String? @map("academic_year_id") @db.Uuid
  name      String
  code      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class  Class? @relation(fields: [classId], references: [id], onDelete: SetNull)
  academicYear AcademicYear? @relation(fields: [academicYearId], references: [id], onDelete: SetNull)
  examPapers ExamPaper[]
  teacherAssignments TeacherSubjectAssignment[]

  @@index([schoolId])
  @@index([classId])
  @@index([academicYearId])
  @@unique([schoolId, name, classId, academicYearId])
  @@map("subjects")
}

enum StudentStatus {
  ENROLLED
  TRANSFERRED
  EXITED
}

enum TransferRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Student {
  id           String        @id @default(uuid()) @db.Uuid
  schoolId     String        @map("school_id") @db.Uuid
  classId      String?       @map("class_id") @db.Uuid
  sectionId    String?       @map("section_id") @db.Uuid
  admissionNo  String        @map("admission_no")
  firstName    String        @map("first_name")
  lastName     String        @map("last_name")
  fullName     String        @map("full_name")
  dob          DateTime?     @map("dob")
  gender       String?       @map("gender")
  bloodGroup   String?       @map("blood_group")
  photoUrl     String?       @map("photo_url")
  fatherName   String?       @map("father_name")
  motherName   String?       @map("mother_name")
  guardianName String?       @map("guardian_name")
  guardianRelationship String? @map("guardian_relationship")
  parentPhone  String?       @map("parent_phone")
  parentEmail  String?       @map("parent_email")
  addressLine1 String?       @map("address_line1")
  addressLine2 String?       @map("address_line2")
  city         String?       @map("city")
  state        String?       @map("state")
  pincode      String?       @map("pincode")
  emergencyContact String?   @map("emergency_contact")
  medicalConditions String?  @map("medical_conditions")
  allergies    String?       @map("allergies")
  doctorContact String?      @map("doctor_contact")
  docBirthCert String?       @map("doc_birth_cert")
  docTransferCert String?    @map("doc_transfer_cert")
  docAadhaar   String?       @map("doc_aadhaar")
  docReportCard String?      @map("doc_report_card")
  status       StudentStatus @default(ENROLLED)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  school       School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class        Class?          @relation(fields: [classId], references: [id], onDelete: SetNull)
  section      Section?        @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  parentLinks  StudentParent[]
  statusEvents StudentStatusHistory[]
  transferRequests StudentTransferRequest[]
  faceProfile  FaceProfile?
  attendanceRecords AttendanceRecord[]
  marks Mark[]
  photos StudentPhoto[]

  @@index([schoolId])
  @@index([classId])
  @@index([sectionId])
  @@unique([schoolId, admissionNo])
  @@map("students")
}

model StudentPhoto {
  id        String   @id @default(uuid()) @db.Uuid
  studentId String   @map("student_id") @db.Uuid
  url       String
  createdAt DateTime @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("student_photos")
}

model StudentTransferRequest {
  id            String   @id @default(uuid()) @db.Uuid
  studentId     String   @map("student_id") @db.Uuid
  fromSchoolId  String   @map("from_school_id") @db.Uuid
  toSchoolId    String   @map("to_school_id") @db.Uuid
  requestedById String   @map("requested_by_id") @db.Uuid
  decidedById   String?  @map("decided_by_id") @db.Uuid
  status        TransferRequestStatus @default(PENDING)
  reason        String?
  decidedAt     DateTime? @map("decided_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  fromSchool School @relation("TransferFromSchool", fields: [fromSchoolId], references: [id], onDelete: Cascade)
  toSchool School @relation("TransferToSchool", fields: [toSchoolId], references: [id], onDelete: Cascade)
  requestedBy User @relation("TransferRequestedBy", fields: [requestedById], references: [id], onDelete: Restrict)
  decidedBy User? @relation("TransferDecidedBy", fields: [decidedById], references: [id], onDelete: Restrict)

  @@index([studentId])
  @@index([fromSchoolId])
  @@index([toSchoolId])
  @@index([status])
  @@map("student_transfer_requests")
}

model ParentProfile {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String?  @map("user_id") @db.Uuid
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  phone        String?
  email        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  links  StudentParent[]
  consents ConsentRecord[]

  @@index([userId])
  @@unique([userId])
  @@map("parent_profiles")
}

model TeacherProfile {
  id          String   @id @default(uuid()) @db.Uuid
  schoolId    String   @map("school_id") @db.Uuid
  userId      String   @unique @map("user_id") @db.Uuid
  employeeNo  String?  @map("employee_no")
  firstName   String   @map("first_name")
  lastName    String   @map("last_name")
  phone       String?
  address     String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankDetails TeacherBankDetails?
  classAssignments TeacherClassAssignment[]
  subjectAssignments TeacherSubjectAssignment[]

  @@index([schoolId])
  @@unique([schoolId, employeeNo])
  @@map("teacher_profiles")
}

model TeacherBankDetails {
  id                String   @id @default(uuid()) @db.Uuid
  teacherId         String   @unique @map("teacher_id") @db.Uuid
  accountHolderName String?  @map("account_holder_name")
  accountNumber     String?  @map("account_number")
  ifscCode          String?  @map("ifsc_code")
  accountType       String?  @map("account_type")
  bankName          String?  @map("bank_name")
  branchName        String?  @map("branch_name")
  panNumber         String?  @map("pan_number")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  teacher TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@map("teacher_bank_details")
}

model UserBankDetails {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @map("user_id") @db.Uuid
  accountHolderName String?  @map("account_holder_name")
  accountNumber     String?  @map("account_number")
  ifscCode          String?  @map("ifsc_code")
  accountType       String?  @map("account_type")
  bankName          String?  @map("bank_name")
  branchName        String?  @map("branch_name")
  panNumber         String?  @map("pan_number")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_bank_details")
}

model TeacherClassAssignment {
  id        String   @id @default(uuid()) @db.Uuid
  teacherId String   @map("teacher_id") @db.Uuid
  classId   String   @map("class_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  teacher TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  class   Class          @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([classId])
  @@unique([teacherId, classId])
  @@map("teacher_class_assignments")
}

model TeacherSubjectAssignment {
  id        String   @id @default(uuid()) @db.Uuid
  teacherId String   @map("teacher_id") @db.Uuid
  subjectId String   @map("subject_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  teacher TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([subjectId])
  @@unique([teacherId, subjectId])
  @@map("teacher_subject_assignments")
}

model StudentParent {
  studentId String @map("student_id") @db.Uuid
  parentId  String @map("parent_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  student Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parent  ParentProfile @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@id([studentId, parentId])
  @@index([parentId])
  @@map("student_parents")
}

model StudentStatusHistory {
  id         String        @id @default(uuid()) @db.Uuid
  studentId  String        @map("student_id") @db.Uuid
  status     StudentStatus
  reason     String?
  changedAt  DateTime      @default(now()) @map("changed_at")
  createdAt  DateTime      @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("student_status_history")
}

enum ImportType {
  STUDENT
  TEACHER
}

enum ImportStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

model ImportJob {
  id              String       @id @default(uuid()) @db.Uuid
  schoolId        String       @map("school_id") @db.Uuid
  createdById     String       @map("created_by_id") @db.Uuid
  type            ImportType
  status          ImportStatus @default(QUEUED)
  filePath        String       @map("file_path")
  originalName    String       @map("original_name")
  totalRows       Int          @default(0) @map("total_rows")
  processedRows   Int          @default(0) @map("processed_rows")
  successCount    Int          @default(0) @map("success_count")
  errorCount      Int          @default(0) @map("error_count")
  dryRun          Boolean      @default(false) @map("dry_run")
  startedAt       DateTime?    @map("started_at")
  finishedAt      DateTime?    @map("finished_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  school   School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdBy User         @relation(fields: [createdById], references: [id], onDelete: Restrict)
  errors   ImportRowError[]

  @@index([schoolId])
  @@index([createdById])
  @@map("import_jobs")
}

model ImportRowError {
  id          String   @id @default(uuid()) @db.Uuid
  importJobId String   @map("import_job_id") @db.Uuid
  rowNumber   Int      @map("row_number")
  field       String?
  message     String
  rawData     Json?    @map("raw_data")
  createdAt   DateTime @default(now()) @map("created_at")

  importJob ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@index([importJobId])
  @@map("import_row_errors")
}

enum FaceProfileStatus {
  PENDING
  APPROVED
  REJECTED
}

model FaceProfile {
  id          String            @id @default(uuid()) @db.Uuid
  schoolId    String            @map("school_id") @db.Uuid
  studentId   String            @unique @map("student_id") @db.Uuid
  status      FaceProfileStatus @default(PENDING)
  createdById String            @map("created_by_id") @db.Uuid
  approvedById String?          @map("approved_by_id") @db.Uuid
  approvedAt  DateTime?         @map("approved_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  school    School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdBy User    @relation("FaceProfileCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  approvedBy User?  @relation("FaceProfileApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  samples   FaceSample[]

  @@index([schoolId])
  @@index([createdById])
  @@index([approvedById])
  @@map("face_profiles")
}

model FaceSample {
  id            String   @id @default(uuid()) @db.Uuid
  faceProfileId String   @map("face_profile_id") @db.Uuid
  imageUrl      String   @map("image_url")
  embedding     Json
  createdAt     DateTime @default(now()) @map("created_at")

  faceProfile FaceProfile @relation(fields: [faceProfileId], references: [id], onDelete: Cascade)

  @@index([faceProfileId])
  @@map("face_samples")
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  EXCUSED
}

enum AttendanceSessionStatus {
  OPEN
  CLOSED
}

enum AttendanceApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model AttendancePeriod {
  id        String   @id @default(uuid()) @db.Uuid
  schoolId  String   @map("school_id") @db.Uuid
  name      String
  startTime String   @map("start_time")
  endTime   String   @map("end_time")
  lateThresholdMinutes Int @default(0) @map("late_threshold_minutes")
  earlyThresholdMinutes Int @default(0) @map("early_threshold_minutes")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  school   School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  sessions AttendanceSession[]

  @@index([schoolId])
  @@unique([schoolId, name])
  @@map("attendance_periods")
}

model AttendanceSession {
  id         String   @id @default(uuid()) @db.Uuid
  schoolId   String   @map("school_id") @db.Uuid
  periodId   String   @map("period_id") @db.Uuid
  date       DateTime @map("date")
  status     AttendanceSessionStatus @default(OPEN)
  approvalStatus AttendanceApprovalStatus @default(PENDING) @map("approval_status")
  approvalReason String? @map("approval_reason")
  startedById String  @map("started_by_id") @db.Uuid
  deviceId   String   @map("device_id")
  gpsLat     Float?   @map("gps_lat")
  gpsLng     Float?   @map("gps_lng")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  school   School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  period   AttendancePeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  startedBy User    @relation(fields: [startedById], references: [id], onDelete: Restrict)
  records  AttendanceRecord[]

  @@index([schoolId])
  @@index([periodId])
  @@index([startedById])
  @@unique([schoolId, periodId, date])
  @@map("attendance_sessions")
}

model AttendanceRecord {
  id         String   @id @default(uuid()) @db.Uuid
  sessionId  String   @map("session_id") @db.Uuid
  studentId  String   @map("student_id") @db.Uuid
  status     AttendanceStatus
  confidence Float?
  capturedAt DateTime @default(now()) @map("captured_at")
  deviceId   String   @map("device_id")
  gpsLat     Float?   @map("gps_lat")
  gpsLng     Float?   @map("gps_lng")
  manualOverrideReason String? @map("manual_override_reason")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  session AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  audits  AttendanceAudit[]
  evidence AttendanceEvidence[]

  @@index([sessionId])
  @@index([studentId])
  @@unique([sessionId, studentId])
