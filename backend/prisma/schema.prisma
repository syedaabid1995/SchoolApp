enum BackupStatus {
  REQUESTED
  RUNNING
  COMPLETED
  FAILED
}

enum RestoreStatus {
  REQUESTED
  APPROVED
  RUNNING
  COMPLETED
  FAILED
}

model BackupJob {
  id            String       @id @default(uuid()) @db.Uuid
  schoolId      String       @map("school_id") @db.Uuid
  status        BackupStatus @default(REQUESTED)
  storagePath   String?      @map("storage_path")
  requestedById String       @map("requested_by_id") @db.Uuid
  reason        String?
  startedAt     DateTime?    @map("started_at")
  finishedAt    DateTime?    @map("finished_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  school      School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  requestedBy User         @relation(fields: [requestedById], references: [id], onDelete: Restrict)
  restores    RestoreJob[]

  @@index([schoolId])
  @@index([requestedById])
  @@map("backup_jobs")
}

model RestoreJob {
  id            String        @id @default(uuid()) @db.Uuid
  backupId      String        @map("backup_id") @db.Uuid
  status        RestoreStatus @default(REQUESTED)
  approvedById  String?       @map("approved_by_id") @db.Uuid
  requestedById String        @map("requested_by_id") @db.Uuid
  reason        String?
  startedAt     DateTime?     @map("started_at")
  finishedAt    DateTime?     @map("finished_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  backup      BackupJob @relation(fields: [backupId], references: [id], onDelete: Cascade)
  approvedBy  User?     @relation("RestoreApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  requestedBy User      @relation("RestoreRequestedBy", fields: [requestedById], references: [id], onDelete: Restrict)

  @@index([backupId])
  @@index([approvedById])
  @@index([requestedById])
  @@map("restore_jobs")
}

